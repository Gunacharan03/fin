# =========================================
# Fin - Backend Environment
# Copy this file to ".env" and fill in real values
# =========================================

# --- MongoDB Atlas ---
# Get this from: Atlas Dashboard > Database > Connect > Drivers > Python
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=fin

# --- JWT Auth ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_long_random_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google Gemini (used by all LangGraph agents) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# --- App Settings ---
APP_NAME=Fin
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- File Uploads ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=app/uploads
